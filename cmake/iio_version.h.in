#ifndef IIO_VERSION_H
#define IIO_VERSION_H

// -----------------------------------------------------------------------------
// Generated by CMake from cmake/iio_version.h.in — do not edit by hand.
//
// Single source of truth for the application version. The numeric components
// come from the project() VERSION in the top-level CMakeLists.txt; the git
// metadata is captured at configure time (empty when git is unavailable).
// -----------------------------------------------------------------------------

#define IIO_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define IIO_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define IIO_VERSION_PATCH @PROJECT_VERSION_PATCH@

// Dotted release string, e.g. "1.0.0".
#define IIO_VERSION_STRING "@PROJECT_VERSION@"

// Short git commit hash (e.g. "a1b2c3d") and branch at configure time. These
// may be empty strings when building outside a git checkout.
#define IIO_GIT_COMMIT "@IIO_GIT_COMMIT@"
#define IIO_GIT_BRANCH "@IIO_GIT_BRANCH@"

// "1.0.0+a1b2c3d" when a commit hash is known, otherwise just "1.0.0".
#define IIO_VERSION_FULL "@IIO_VERSION_FULL@"

#endif // IIO_VERSION_H
